{
  "name": "@transitionsag/forms",
  "version": "0.0.1",
  "license": "MIT",
  "tasks": {
    "test": "deno test --no-check --allow-env --conditions=browser --ignore=src/**/*.test.tsx src/errors/ src/resolver/ && deno test --no-check --allow-env --conditions=browser --ignore=src/**/*.test.tsx src/form.test.ts && deno run -A npm:vitest run",
    "test:unit": "deno test --no-check --allow-env --conditions=browser --ignore=src/**/*.test.tsx src/",
    "test:component": "deno run -A npm:vitest run"
  },
  "exports": {
    ".": "./src/mod.ts",
    "./resolver": "./src/resolver/mod.ts",
    "./resolver/zod": "./src/resolver/zod.ts"
  },
  "publish": {
    "include": ["src/", "deno.json", "README.md", "LICENSE"],
    "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx", "src/jsx.ts"]
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.8"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "solid-js",
    "lib": ["DOM", "DOM.Iterable", "ESNext"]
  }
}
